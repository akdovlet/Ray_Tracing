# Bump map test scene
# sp [pos] [diameter] [RGB] [emission] [bump.xpm]
# pl [pos] [normal] [RGB]
# L  [pos] [brightness] [RGB]
# A  [ratio] [RGB]
# C  [pos] [dir] [FOV]

A 0.2 255,255,255
C 0,2,-6 0,-0.2,1 60

L -5,8,-2 1 255,255,255

sp 0,1,0   3   200,200,200   0   ./xpm/albedo.xpm
sp 4,2,0   3   200,0,0   1.0
pl 0,-0.5,0   0,1,0   80,80,80
